<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                pricehistory_view_listing.pricehistory_view_listing_data_source
            </item>
        </item>
    </argument>
    <settings>
        <spinner>pricehistory_view_columns</spinner>
        <deps>
            <dep>pricehistory_view_listing.pricehistory_view_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="pricehistory_view_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
        </settings>
        <aclResource>Mavenbird_ProductPriceHistory::menu</aclResource>
        <dataProvider
            class="Mavenbird\ProductPriceHistory\Ui\DataProvider\PriceHistory\ViewDataProvider"
            name="pricehistory_view_listing_data_source">
            <settings>
                <primaryFieldName>id</primaryFieldName>
                <requestFieldName>product_id</requestFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <paging name="listing_paging"/>
        <filters name="listing_filters"/>
    </listingToolbar>
    <columns name="pricehistory_view_columns">
        <column name="id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="product_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Product Name</label>
            </settings>
        </column>
        <column name="old_price">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Old Price</label>
            </settings>
        </column>
        <column name="new_price">
            <settings>
                <filter>textRange</filter>
                <label translate="true">New Price</label>
            </settings>
        </column>
        <column name="price_diff"
                class="Mavenbird\ProductPriceHistory\Ui\Component\Listing\Column\PriceDiff">
            <settings>
                <label translate="true">Change (+ / -)</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="store_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Store ID</label>
            </settings>
        </column>
        <column name="changed_at"
                class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Changed At</label>
            </settings>
        </column>
        <column name="changed_by_user">
            <settings>
                <filter>text</filter>
                <label translate="true">Changed By</label>
            </settings>
        </column>
    </columns>
</listing>